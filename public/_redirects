# Cloudflare Pages 301 redirects — only for old WordPress URLs whose slug CHANGED.
# Same-slug paths (/contact, /portfolio, /accreditations) are served at both
# /x and /x/ automatically — a self-referential redirect there causes a loop.
/about-us            /about                  301
/about-us/           /about                  301
/renewables          /services/heat-pumps    301
/renewables/         /services/heat-pumps    301
