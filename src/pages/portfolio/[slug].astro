---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { projects, company } from '../../data/site';
import { photosFor } from '../../lib/photos';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project: p } = Astro.props;
const gallery = photosFor(p.photoPrefix, p.photoCount);
const hero = gallery[0];
const rest = gallery.slice(1);
const related = projects.filter((r) => r.slug !== p.slug && r.sectorSlug === p.sectorSlug).slice(0, 3);
const fallback = projects.filter((r) => r.slug !== p.slug).slice(0, 3);
const relatedShown = related.length ? related : fallback;
---
<Base
  title={`${p.name} - ${p.value} · 21 Degrees Heating`}
  description={p.summary}
  ogImage="/og-default.jpg"
>
  <!-- Hero -->
  <section class="relative isolate flex min-h-[68svh] items-end overflow-hidden bg-slate-ink">
    {hero && (
      <Image src={hero} alt={`${p.name} - installed by 21 Degrees Heating`} class="absolute inset-0 -z-10 h-full w-full object-cover opacity-65" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
    )}
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-slate-ink via-slate-ink/70 to-slate-ink/30"></div>
    <div class="mx-auto w-full max-w-7xl px-5 pb-14 pt-32 lg:px-8">
      <a href="/portfolio" class="text-sm font-medium text-bone/70 hover:text-teal-400">&larr; All projects</a>
      <div class="mt-4 flex flex-wrap items-center gap-2.5">
        <a href={`/sectors/${p.sectorSlug}`} class="rounded-full bg-bone/15 px-3 py-1 text-xs font-medium text-bone backdrop-blur-sm hover:bg-bone/25">{p.sector}</a>
        <span class="rounded-full bg-teal px-3 py-1 text-xs font-semibold text-bone tnum">{p.value}</span>
      </div>
      <h1 class="h-display mt-5 max-w-3xl text-5xl text-bone sm:text-6xl">{p.name}</h1>
      <p class="mt-4 max-w-2xl text-lg text-bone/80">{p.summary}</p>
    </div>
  </section>

  <!-- Specs band -->
  <section class="border-b border-slate-ink/10 bg-bone">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-px px-5 lg:grid-cols-4 lg:px-8">
      {p.specs.map((s) => (
        <div class="px-2 py-7 lg:px-6">
          <p class="text-xs uppercase tracking-wide text-steel">{s.label}</p>
          <p class="mt-1.5 font-display text-2xl font-semibold text-slate-ink tnum">{s.value}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Overview + scope -->
  <section class="bg-bone py-18 lg:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 lg:grid-cols-[1.4fr_1fr] lg:px-8">
      <div class="reveal">
        <p class="eyebrow mb-3">Project overview</p>
        <div class="space-y-4 text-base leading-relaxed text-slate-ink/80">
          {p.narrative.map((para) => <p>{para}</p>)}
        </div>
        <div class="mt-8 grid grid-cols-2 gap-5 border-t border-slate-ink/10 pt-6 text-sm">
          <div><p class="text-steel">Client</p><p class="font-semibold text-slate-ink">{p.client}</p></div>
          <div><p class="text-steel">Location</p><p class="font-semibold text-slate-ink">{p.location}</p></div>
        </div>
      </div>
      <aside class="reveal">
        <div class="rounded-3xl border border-slate-ink/10 bg-bone-200/50 p-7">
          <p class="eyebrow mb-4">Scope of works</p>
          <ul class="space-y-3 text-sm text-slate-ink/80">
            {p.scope.map((item) => (
              <li class="flex gap-2.5"><span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-teal"></span>{item}</li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- Gallery -->
  {rest.length > 0 && (
    <section class="bg-bone-200/40 py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <p class="eyebrow mb-6 reveal">On site</p>
        <div class="grid grid-cols-2 gap-4 md:grid-cols-3">
          {rest.map((img, i) => (
            <div class={`overflow-hidden rounded-2xl reveal ${i % 5 === 0 ? 'col-span-2 md:col-span-2' : ''}`}>
              <Image src={img} alt={`${p.name} - installation detail ${i + 2}`} class="h-full w-full object-cover" widths={[400, 800]} sizes="(max-width:768px) 50vw, 33vw" />
            </div>
          ))}
        </div>
        <p class="mt-4 text-xs text-steel">Project photography from site. Higher-resolution imagery available on request.</p>
      </div>
    </section>
  )}

  <!-- Related -->
  <section class="bg-slate-ink py-18 text-bone lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <p class="eyebrow mb-6">Related projects</p>
      <div class="grid gap-5 sm:grid-cols-3">
        {relatedShown.map((r) => (
          <a href={`/portfolio/${r.slug}`} class="group rounded-2xl border border-white/10 bg-slate-800 p-6 transition-colors hover:border-teal/40">
            <p class="text-xs text-steel-light">{r.sector}</p>
            <h3 class="mt-2 font-display text-xl font-semibold text-bone group-hover:text-teal-400">{r.name}</h3>
            <p class="mt-1 font-semibold text-teal-400 tnum">{r.value}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-teal py-16 text-center text-bone">
    <div class="mx-auto max-w-2xl px-5">
      <h2 class="h-display text-3xl sm:text-4xl">Delivering something similar? <span class="font-semibold">Let’s talk.</span></h2>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href={`tel:${company.phoneHref}`} class="rounded-full bg-slate-ink px-7 py-3.5 font-semibold text-bone hover:bg-slate-700 tnum">{company.phoneDisplay}</a>
        <a href="/contact" class="rounded-full border border-bone/40 px-7 py-3.5 font-semibold text-bone hover:bg-bone/10">Discuss a project</a>
      </div>
    </div>
  </section>
</Base>
