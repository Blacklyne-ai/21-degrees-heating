---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import { company, reasons, accreditations } from '../data/site';
import { getPhoto } from '../lib/photos';

const portrait = getPhoto('middlesex-york-05')!;
const inHouse = [
  { title: 'In-house design office', body: 'Full M&E, electrical and BMS design - so what we draw is what we build.' },
  { title: 'Our own pipe fabrication', body: 'A fabrication shop most contractors subcontract. It gives clients delivery certainty.' },
  { title: 'In-house ground works', body: 'Excavation, directional drilling and civils kept under our own programme.' },
  { title: 'Own boiler fleet', body: 'Temporary plant from 100kW to 2MW for emergency heat and hot water cover.' },
];
---
<Base
  title="About — 21 Degrees Heating"
  description="Founded in 2004 by Jonathan Mark Smith, 21 Degrees Heating is a commercial M&E heating contractor with 20+ in-house staff, delivering across London and the Home Counties for 22 years."
>
  <PageHeader
    eyebrow="The company"
    title='22 years. 20+ in-house staff. <span class="font-semibold">One accountable contractor.</span>'
    sub="A commercial M&E heating contractor that designs, fabricates, installs and maintains - from our Battersea works."
    ghost="2004"
  />

  <!-- Narrative -->
  <section class="bg-bone py-16 lg:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 lg:grid-cols-[1.3fr_1fr] lg:px-8">
      <div class="reveal space-y-5 text-lg leading-relaxed text-slate-ink/80">
        <p>21 Degrees Heating Ltd specialise in the design, manufacture, supply, installation, testing and commissioning of industrial and commercial heating services. We offer a full in-house design service, and run our own pipe fabrication service, giving clients greater certainty on project delivery than the industry norm.</p>
        <p>As the company has grown, we have incorporated further services - full electrical and BMS design, district heating, Air Source Heat Pumps, AC and ventilation, and our own in-house ground works team. We also supply and service our own temporary boiler plants, from 100kW to 2MW, for emergency heating and hot water.</p>
        <p>Our main area of work is within the social housing sector, large commercial refurbishment and commercial new build - installing plant rooms, heating, gas and cold water distribution, and in-flat pipework, radiators, boilers and HIUs. Our commitment to first-class delivery is reflected in a high level of repeat business.</p>
      </div>
      <aside class="reveal">
        <div class="rounded-3xl border border-slate-ink/10 bg-bone-200/50 p-7">
          <p class="eyebrow mb-4">At a glance</p>
          <dl class="space-y-4 text-sm">
            <div class="flex justify-between gap-4"><dt class="text-steel">Founded</dt><dd class="font-semibold text-slate-ink tnum">{company.incorporated}</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-steel">Director</dt><dd class="font-semibold text-slate-ink">{company.director}</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-steel">Staff</dt><dd class="font-semibold text-slate-ink">{company.staff}</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-steel">Company no.</dt><dd class="font-semibold text-slate-ink tnum">{company.companyNumber}</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-steel">Net assets</dt><dd class="font-semibold text-slate-ink tnum">{company.netAssets}</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-steel">SIC</dt><dd class="text-right font-medium text-slate-ink">43220 - Plumbing, heat & AC installation</dd></div>
          </dl>
        </div>
      </aside>
    </div>
  </section>

  <!-- Founder -->
  <section class="bg-slate-ink py-16 text-bone lg:py-24">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 lg:grid-cols-[1fr_1.2fr] lg:px-8">
      <div class="relative overflow-hidden rounded-3xl reveal reveal-l">
        <Image src={portrait} alt="21 Degrees Heating installation" class="aspect-[4/5] h-full w-full object-cover" widths={[420, 700]} sizes="(max-width:1024px) 100vw, 40vw" />
      </div>
      <div class="reveal">
        <p class="eyebrow mb-3">Leadership</p>
        <h2 class="h-display text-3xl text-bone sm:text-4xl"><span class="font-semibold">{company.director}</span>, Founder &amp; Director</h2>
        <p class="mt-5 text-lg leading-relaxed text-steel-light">
          Jonathan Mark Smith founded 21 Degrees Heating in 2004 and still leads the business today. We pride ourselves on having team members who have been with the company since its foundation - continuity of knowledge that shows on every project we deliver, from Tower Bridge to City of London estates.
        </p>
        <p class="mt-4 text-sm text-steel-light/80">A professional photo of the director can replace this image once supplied.</p>
      </div>
    </div>
  </section>

  <!-- In-house capability -->
  <section class="bg-bone py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="mb-10 max-w-2xl reveal">
        <p class="eyebrow mb-3">What makes us different</p>
        <h2 class="h-display text-3xl text-slate-ink sm:text-4xl">Everything <span class="font-semibold">in-house.</span></h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {inHouse.map((c) => (
          <div class="rounded-3xl border border-slate-ink/10 bg-bone-200/50 p-7 reveal">
            <h3 class="font-display text-lg font-semibold text-slate-ink">{c.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-ink/70">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reasons -->
  <section class="bg-bone-200/40 py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-px overflow-hidden rounded-3xl border border-slate-ink/10 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {reasons.map((r) => (
          <div class="bg-bone p-7 reveal">
            <span class="font-display text-3xl font-semibold text-teal tnum">{r.no}</span>
            <h3 class="mt-4 font-display text-lg font-semibold text-slate-ink">{r.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-ink/70">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accreditations + addresses -->
  <section class="bg-bone py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <p class="mb-6 text-center text-sm font-medium text-steel">Independently accredited across health & safety, gas, electrical, renewables and access</p>
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-5">
        {accreditations.filter((a) => a.img).map((a) => (
          <img src={a.img} alt={a.full} width="120" height="48" loading="lazy" class="h-10 w-auto object-contain opacity-80 grayscale transition hover:opacity-100 hover:grayscale-0" title={a.full} />
        ))}
        <a href="/accreditations" class="text-sm font-semibold text-teal hover:text-teal-600">All 12 &rarr;</a>
      </div>
      <div class="mx-auto mt-12 grid max-w-3xl gap-6 sm:grid-cols-2">
        <div class="rounded-2xl border border-slate-ink/10 bg-bone-200/50 p-6">
          <p class="eyebrow mb-2">Trading address</p>
          <p class="text-sm text-slate-ink/80">{company.tradingAddress}</p>
        </div>
        <div class="rounded-2xl border border-slate-ink/10 bg-bone-200/50 p-6">
          <p class="eyebrow mb-2">Registered office</p>
          <p class="text-sm text-slate-ink/80">{company.registeredOffice}</p>
        </div>
      </div>
    </div>
  </section>

  <ClosingCTA />
</Base>
