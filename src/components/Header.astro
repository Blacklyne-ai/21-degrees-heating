---
import Wordmark from './Wordmark.astro';
import { company, nav } from '../data/site';
---
<header id="site-header" class="fixed inset-x-0 top-0 z-50 text-bone transition-all duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3.5 lg:px-8">
    <Wordmark />

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary">
      {nav.map((n) => (
        <a href={n.href} class="text-sm font-medium text-current opacity-80 transition-opacity hover:opacity-100 hover:text-teal">{n.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2.5">
      <a href={`tel:${company.phoneHref}`} class="hidden text-sm font-semibold text-current transition-colors hover:text-teal sm:inline tnum">{company.phoneDisplay}</a>
      <a href="/capability-statement" class="hidden rounded-full border border-current px-4 py-2 text-sm font-semibold text-current transition-colors hover:border-teal hover:text-teal md:inline-block">Capability statement</a>
      <button id="nav-toggle" class="grid h-10 w-10 place-items-center rounded-full border border-current/40 text-current lg:hidden" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-nav" class="hidden border-t border-slate-ink/10 bg-bone/95 text-slate-ink backdrop-blur-md lg:hidden">
    <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-5 py-4" aria-label="Mobile">
      {nav.map((n) => (
        <a href={n.href} class="rounded-lg px-3 py-2.5 text-base font-medium text-slate-ink hover:bg-bone-200">{n.label}</a>
      ))}
      <div class="mt-2 flex flex-col gap-2">
        <a href={`tel:${company.phoneHref}`} class="rounded-full bg-slate-ink px-4 py-3 text-center text-sm font-semibold text-bone">Call {company.phoneDisplay}</a>
        <a href="/capability-statement" class="rounded-full border border-slate-ink/20 px-4 py-3 text-center text-sm font-semibold text-slate-ink">Capability statement</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const onScroll = () => {
    header.classList.toggle('is-scrolled', window.scrollY > 12);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('mobile-nav')!;
  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
  });
</script>

<style>
  #site-header.is-scrolled {
    color: #1c2a33;
    background-color: color-mix(in srgb, #f4efe6 82%, transparent);
    backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 0 color-mix(in srgb, #1c2a33 8%, transparent);
  }
</style>
