---
import Wordmark from './Wordmark.astro';
import { company, nav } from '../data/site';
---
<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto max-w-6xl px-3 pt-3 lg:pt-4">
    <!-- Floating glass pill -->
    <div class="glass-dark flex items-center justify-between gap-3 rounded-full px-3 py-2 text-bone lg:px-4">
      <Wordmark class="pl-1" />

      <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
        {nav.map((n) => (
          <a href={n.href} class="text-[0.82rem] font-medium text-bone/75 transition-colors hover:text-teal-400">{n.label}</a>
        ))}
      </nav>

      <div class="flex items-center gap-2">
        <a href={`tel:${company.phoneHref}`} class="hidden text-sm font-semibold text-bone transition-colors hover:text-teal-400 sm:inline tnum">{company.phoneDisplay}</a>
        <a href="/capability-statement" class="hidden rounded-full bg-teal px-4 py-2 text-[0.82rem] font-semibold text-bone transition-colors hover:bg-teal-600 md:inline-block">Capability</a>
        <button id="nav-toggle" class="grid h-9 w-9 place-items-center rounded-full border border-bone/25 text-bone lg:hidden" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav panel -->
    <div id="mobile-nav" class="glass-dark mt-2 hidden rounded-3xl p-3 text-bone lg:hidden">
      <nav class="flex flex-col gap-0.5" aria-label="Mobile">
        {nav.map((n) => (
          <a href={n.href} class="rounded-xl px-4 py-2.5 text-base font-medium text-bone/90 hover:bg-bone/10">{n.label}</a>
        ))}
        <div class="mt-2 flex flex-col gap-2 px-1 pb-1">
          <a href={`tel:${company.phoneHref}`} class="rounded-full bg-teal px-4 py-3 text-center text-sm font-semibold text-bone">Call {company.phoneDisplay}</a>
          <a href="/capability-statement" class="rounded-full border border-bone/25 px-4 py-3 text-center text-sm font-semibold text-bone">Capability statement</a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('mobile-nav')!;
  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
  });
</script>
