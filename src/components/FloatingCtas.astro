---
import { company } from '../data/site';
---
<div id="floating-ctas" class="pointer-events-none fixed bottom-4 left-4 z-40 flex flex-col gap-2 opacity-0 transition-opacity duration-300">
  <a href={`tel:${company.phoneHref}`} class="pointer-events-auto inline-flex items-center gap-2 rounded-full bg-slate-ink px-4 py-3 text-sm font-semibold text-bone shadow-lg" aria-label={`Call ${company.phoneDisplay}`}>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M5.2 2.5 6.6 5l-1.3 1.3a8 8 0 0 0 3.4 3.4L10 8.4l2.5 1.4.5 2.7a1 1 0 0 1-1 1.2A10.5 10.5 0 0 1 2.3 4a1 1 0 0 1 1.2-1l1.7.5Z" fill="currentColor"/></svg>
    Call
  </a>
  <a href="/services/emergency-boiler-hire" class="pointer-events-auto inline-flex items-center gap-2 rounded-full bg-teal px-4 py-3 text-sm font-semibold text-bone shadow-lg" aria-label="24/7 emergency boiler hire">
    <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-bone opacity-70"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-bone"></span></span>
    Emergency hire
  </a>
</div>

<script>
  const el = document.getElementById('floating-ctas')!;
  const onScroll = () => {
    if (window.scrollY > 200) { el.style.opacity = '1'; }
    else { el.style.opacity = '0'; }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
