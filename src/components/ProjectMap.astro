---
import { projects, sectors } from '../data/site';
// Distinct sectors present in the project set, in display order
const sectorList = sectors.filter((s) => projects.some((p) => p.sectorSlug === s.slug));
---
<section class="bg-slate-ink py-20 text-bone lg:py-28" aria-labelledby="map-heading">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="max-w-2xl reveal">
      <p class="eyebrow mb-3">Ten named projects · one map</p>
      <h2 id="map-heading" class="h-display text-4xl text-bone sm:text-5xl">
        <span class="font-semibold">£10M+ delivered</span> across London<br />and the South East.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-steel-light">
        Every pin is a named, delivered project - value, sector and scope confirmed. Hover or tap a marker, or filter by sector.
      </p>
    </div>

    <!-- Sector filter -->
    <div class="mt-8 flex flex-wrap gap-2 reveal" role="group" aria-label="Filter projects by sector">
      <button data-filter="all" class="map-filter is-active rounded-full border border-white/20 px-4 py-1.5 text-sm font-medium transition-colors">All sectors</button>
      {sectorList.map((s) => (
        <button data-filter={s.slug} class="map-filter rounded-full border border-white/20 px-4 py-1.5 text-sm font-medium transition-colors">{s.name}</button>
      ))}
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[1.55fr_1fr]">
      <!-- Map -->
      <div id="map-canvas" class="relative aspect-[16/11] overflow-hidden rounded-3xl border border-white/10 bg-slate-900 reveal">
        <svg viewBox="0 0 160 110" class="absolute inset-0 h-full w-full" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
          <defs>
            <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
              <path d="M10 0H0V10" fill="none" stroke="#ffffff" stroke-width="0.25" stroke-opacity="0.06" />
            </pattern>
            <filter id="thames-glow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="1.4" result="b" /><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <rect width="160" height="110" fill="url(#grid)" />
          <!-- River Thames, stylised ribbon W→E with London meanders -->
          <path d="M-5 64 C 25 58, 38 70, 58 66 C 72 63, 78 78, 92 74 C 104 71, 112 60, 126 62 C 140 64, 150 56, 168 60"
                fill="none" stroke="#00769E" stroke-width="2.4" stroke-opacity="0.45" stroke-linecap="round" filter="url(#thames-glow)" />
          <path id="thames-line" d="M-5 64 C 25 58, 38 70, 58 66 C 72 63, 78 78, 92 74 C 104 71, 112 60, 126 62 C 140 64, 150 56, 168 60"
                fill="none" stroke="#3a9cc0" stroke-width="0.7" stroke-opacity="0.95" stroke-linecap="round" />
        </svg>

        {projects.map((p, i) => (
          <button
            class="map-pin group absolute -translate-x-1/2 -translate-y-1/2"
            style={`left:${p.map.x}%; top:${p.map.y}%; --pi:${i}`}
            data-sector={p.sectorSlug}
            data-name={p.name}
            data-value={p.value}
            data-sectorname={p.sector}
            data-summary={p.summary}
            data-href={`/portfolio/${p.slug}`}
            aria-label={`${p.name} - ${p.value}, ${p.sector}`}
          >
            <span class="relative grid h-3.5 w-3.5 place-items-center">
              <span class="pin-ping absolute h-3.5 w-3.5 rounded-full bg-teal/50"></span>
              <span class="absolute h-3.5 w-3.5 rounded-full bg-teal/30 transition-transform duration-300 group-hover:scale-[2.6]"></span>
              <span class="pin-dot relative h-2.5 w-2.5 rounded-full border border-bone/70 bg-teal transition-transform duration-300 group-hover:scale-125"></span>
            </span>
          </button>
        ))}
        <span class="absolute bottom-3 right-4 text-[0.65rem] uppercase tracking-[0.18em] text-steel-light/70">London &amp; the South East</span>
      </div>

      <!-- Detail card / list fallback -->
      <div>
        <div id="map-detail" class="rounded-3xl border border-white/10 bg-slate-800 p-6 reveal">
          <p class="eyebrow" id="md-sector">Heritage</p>
          <h3 class="mt-2 font-display text-2xl font-semibold text-bone" id="md-name">Tower Bridge</h3>
          <p class="mt-1 text-3xl font-semibold text-teal-400 tnum" id="md-value">£800,000</p>
          <p class="mt-3 text-sm leading-relaxed text-steel-light" id="md-summary">Two new commercial boiler rooms and full distribution pipework inside a working heritage landmark.</p>
          <a id="md-link" href="/portfolio/tower-bridge" class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-bone hover:text-teal-400">
            View case study
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 7h8M7.5 3.5 11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <p class="mt-3 px-1 text-xs text-steel-light/70">Tip: every project also has its own page under <a href="/portfolio" class="underline underline-offset-2 hover:text-bone">Projects</a>.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .map-filter.is-active { background-color: #00769E; border-color: #00769E; color: #F4EFE6; }
  .map-filter { transition: background-color .25s ease, border-color .25s ease, color .25s ease; }
  .map-pin { cursor: pointer; transition: opacity .4s ease; }
  .map-pin.dimmed { opacity: 0.18; }
  .map-pin .pin-dot { box-shadow: 0 0 0 0 rgba(0,118,158,0); transition: box-shadow .3s ease, transform .3s ease; }
  .map-pin.active .pin-dot { box-shadow: 0 0 0 5px rgba(0,118,158,0.35); transform: scale(1.25); }
  .map-pin .pin-ping { opacity: 0; }

  /* Thames draws in when the map enters view */
  #thames-line { stroke-dasharray: 320; stroke-dashoffset: 320; }
  .map-live #thames-line { animation: draw 2.2s cubic-bezier(0.16,1,0.3,1) forwards; }
  @keyframes draw { to { stroke-dashoffset: 0; } }

  /* Pins drop in (staggered), then gently ping */
  .map-pin { opacity: 0; transform: translate(-50%,-50%) scale(0.2); }
  .map-live .map-pin { animation: pindrop .5s cubic-bezier(0.16,1,0.3,1) forwards; animation-delay: calc(0.9s + var(--pi) * 90ms); }
  @keyframes pindrop { to { opacity: 1; transform: translate(-50%,-50%) scale(1); } }
  .map-live .map-pin.dimmed { opacity: .18; }
  .map-live .pin-ping { animation: ping 2.6s ease-out infinite; animation-delay: calc(1.6s + var(--pi) * 90ms); }
  @keyframes ping { 0% { opacity:.6; transform:scale(1);} 70%,100% { opacity:0; transform:scale(3.2);} }

  @media (prefers-reduced-motion: reduce) {
    #thames-line { stroke-dashoffset: 0; }
    .map-pin { opacity: 1; transform: translate(-50%,-50%); animation: none !important; }
    .map-live .pin-ping { animation: none; }
  }
  :focus-visible { outline-offset: 4px; }
</style>

<script>
  const detail = {
    sector: document.getElementById('md-sector')!,
    name: document.getElementById('md-name')!,
    value: document.getElementById('md-value')!,
    summary: document.getElementById('md-summary')!,
    link: document.getElementById('md-link') as HTMLAnchorElement,
  };
  const pins = Array.from(document.querySelectorAll<HTMLButtonElement>('.map-pin'));

  // Kick off draw + pin-drop when the map enters the viewport
  const canvas = document.getElementById('map-canvas');
  if (canvas) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) if (e.isIntersecting) { canvas.classList.add('map-live'); io.disconnect(); }
    }, { threshold: 0.25 });
    io.observe(canvas);
  }

  function show(pin: HTMLButtonElement) {
    detail.sector.textContent = pin.dataset.sectorname!;
    detail.name.textContent = pin.dataset.name!;
    detail.value.textContent = pin.dataset.value!;
    detail.summary.textContent = pin.dataset.summary!;
    detail.link.href = pin.dataset.href!;
    pins.forEach((p) => p.classList.remove('active'));
    pin.classList.add('active');
  }
  pins.forEach((pin) => {
    pin.addEventListener('mouseenter', () => show(pin));
    pin.addEventListener('focus', () => show(pin));
    pin.addEventListener('click', () => { window.location.href = pin.dataset.href!; });
  });

  // Sector filter
  const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('.map-filter'));
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const f = btn.dataset.filter!;
      pins.forEach((p) => p.classList.toggle('dimmed', f !== 'all' && p.dataset.sector !== f));
    });
  });
</script>
